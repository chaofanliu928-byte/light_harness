# 本地配置(仅排除仓库根 Claude Code 用户级配置 + harness 子目录 user override)
# /.claude/ 锚定 root,不影响 harness/.claude/(harness 自身的 hook/skill/agent — 应 tracked)
/.claude/
harness/.claude/settings.local.json

# 打包产物
*.zip
*.tar.gz

# 运行时产物
docs/active/
docs/completed/
docs/audits/*.md
!docs/audits/.gitkeep

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 编辑器
.vscode/
.idea/
*.swp
*.swo

# 日志
*.log

# 临时文件
/tmp/
*.tmp
